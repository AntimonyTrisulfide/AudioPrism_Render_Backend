# Local backend environment.
# Copy to .env and fill real secrets. .env is git-ignored.

AUTH_REQUIRED=1
MONGO_REQUIRED=1
MONGODB_URI=mongodb+srv://USER:URL_ENCODED_PASSWORD@cluster0.example.mongodb.net/audioprism?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=audioprism
MONGODB_TIMEOUT_MS=15000
JWT_SECRET=replace-with-a-long-random-secret

MAX_UPLOAD_MB=25
MAX_AUDIO_SECONDS=0
INFERENCE_CHUNK_SECONDS=0.5
INFERENCE_FREQ_TILE_BINS=256
INFERENCE_FREQ_OVERLAP_BINS=64
INFERENCE_AUTOTUNE_FOR_RAM=1
OUTPUT_TTL_MINUTES=120
INFERENCE_JOB_TTL_SECONDS=3600
RAM_LIMIT_MB=512
# Include your deployed frontend origin exactly as shown in the browser address bar, without a path.
# Trailing slashes are normalized by the app, but keeping this clean makes deploys easier to inspect.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.vercel.app
# Optional: allow preview deployments, for example Vercel branch URLs.
# ALLOWED_ORIGIN_REGEX=^https://.*\.vercel\.app$
PUBLIC_BASE_URL=https://your-backend.onrender.com

# Optional persistent stem storage.
# SUPABASE_URL must be the Project URL, not the Postgres/database URL.
STORAGE_BACKEND=supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-backend-only-service-role-or-secret-key
SUPABASE_BUCKET=audioprism-stems
SUPABASE_PUBLIC_BUCKET=0

# Final UNet checkpoint.
MODEL_FILENAME=model_render.pth
# MODEL_PATH=C:\path\to\model_render.pth
